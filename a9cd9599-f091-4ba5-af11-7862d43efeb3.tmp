</style><style data-savepage-href="https://s.uicdn.com/mailint/10.181.0/assets/_sn_/lod/../css/mailcom/mod-welcomeback/welcomeback.css">[data-mod-name=welcomeback]{--gap:2rem}[data-mod-name=welcomeback] .close-bar,[data-mod-name=welcomeback] .dialogContent{max-width:1080px}[data-mod-name=welcomeback] .dialogOverlay{--z-index:9999;top:0;bottom:0;left:0;right:0;background-color:rgba(0,0,0,.6);z-index:var(--z-index);display:table;width:100%;height:100%;position:fixed;transition:background-color .3s ease-out}[data-mod-name=welcomeback] .dialogOverlay.fadeIn{background-color:rgba(0,0,0,.8)}[data-mod-name=welcomeback] .dialogWrapper{display:table-cell;vertical-align:middle;padding:var(--gap);animation-duration:1s;animation-fill-mode:forwards;animation-timing-function:ease-out}[data-mod-name=welcomeback] .dialogWrapper.opened{animation-name:open}[data-mod-name=welcomeback] .dialogWrapper.closed{animation-name:close}[data-mod-name=welcomeback] .dialogWrapper.bouncein{animation-name:bounceIn}[data-mod-name=welcomeback] .dialogWrapper.bounceout{animation-name:bounceOut}[data-mod-name=welcomeback] .dialogContent{box-sizing:border-box;clear:both;margin:auto;overflow:auto;position:relative;background-color:#fff;color:#000;padding:0 var(--gap) var(--gap) var(--gap);box-shadow:0 2.8px 2.2px rgba(0,0,0,.02),0 6.7px 5.3px rgba(0,0,0,.028),0 12.5px 10px rgba(0,0,0,.035),0 22.3px 17.9px rgba(0,0,0,.042),0 41.8px 33.4px rgba(0,0,0,.05),0 100px 80px rgba(0,0,0,.07)}[data-mod-name=welcomeback] .close-bar{background-color:#fff;height:var(--gap);text-align:right;margin:auto}[data-mod-name=welcomeback] .close-bar .icon-close{position:relative;top:12px;right:16px;z-index:var(--z-index);cursor:pointer;border:none;background-color:transparent}[data-mod-name=welcomeback] .dialogWrapper .close-bar .icon-close{display:inline-block;width:3.2rem;height:3.2rem;margin-top:.5rem;background-size:100%;background-repeat:no-repeat;background-image:url("data:image/svg+xml;charset=utf-8,%3Csvg width='32' height='32' xmlns='http://www.w3.org/2000/svg'%3E%3Cdefs%3E%3Cfilter id='a'%3E%3CfeColorMatrix in='SourceGraphic' values='0 0 0 0 0.200000 0 0 0 0 0.200000 0 0 0 0 0.200000 0 0 0 1.000000 0'/%3E%3C/filter%3E%3C/defs%3E%3Cg filter='url(%23a)' fill='none' fill-rule='evenodd'%3E%3Cpath d='M23.507 21.387l-5.289-5.397 5.289-5.377c.681-.745.62-1.57 0-2.175-.64-.604-1.694-.564-2.273 0-.413.403-3.512 3.565-5.226 5.296-1.715-1.731-4.814-4.893-5.247-5.296-.6-.564-1.653-.604-2.273 0-.62.604-.681 1.43 0 2.175l5.289 5.377-5.289 5.397c-.681.725-.62 1.57 0 2.175.64.604 1.694.564 2.273 0 .413-.403 3.511-3.544 5.226-5.296a833.275 833.275 0 005.227 5.296c.599.564 1.652.604 2.272 0 .66-.624.702-1.45.02-2.175z' fill='%23000' fill-rule='nonzero'/%3E%3C/g%3E%3C/svg%3E")}[data-mod-name=welcomeback] .wbcontent{display:flex;margin:var(--gap) 0}[data-mod-name=welcomeback] .btn{position:absolute;top:4.6rem;left:var(--gap);background-color:var(--button-wbs)}[data-mod-name=welcomeback] .btn:hover{background-color:var(--button-hover-primary)}[data-mod-name=welcomeback] .wbcontent__teasers{display:flex;flex:1;flex-direction:column;justify-content:space-between;padding-top:4.6rem}[data-mod-name=welcomeback] .wbcontent__teasers.blog{padding-top:0}[data-mod-name=welcomeback] .teaser-list-horizontal{display:flex;flex-wrap:wrap;clear:both}[data-mod-name=welcomeback] .wbcontent__hpad{display:none;overflow:hidden;width:300px}@media (min-width:64em){[data-mod-name=welcomeback] .wbcontent__hpad{display:block}}[data-mod-name=welcomeback] .co-wbhalfpage{height:100%}[data-mod-name=welcomeback] .block{float:left;width:350px;margin-right:var(--gap);margin-top:var(--gap)}[data-mod-name=welcomeback] [data-mod-name=teaser].teaser-card,[data-mod-name=welcomeback] [data-mod-name=tool]{float:left;width:calc(50% - var(--gap));max-width:350px;height:250px;margin-right:var(--gap);margin-top:var(--gap)}[data-mod-name=welcomeback] [data-mod-name=teaser].teaser-card .teaser-image,[data-mod-name=welcomeback] [data-mod-name=tool] .teaser-image{height:auto}@media (max-width:1023px){[data-mod-name=welcomeback] [data-mod-name=teaser].teaser-card .teaser-text,[data-mod-name=welcomeback] [data-mod-name=tool] .teaser-text{height:unset;overflow:auto}}@media (max-width:1023px){[data-mod-name=welcomeback] [data-mod-name=tool]{height:auto;min-height:25rem}}@media (max-width:1023px){[data-mod-name=welcomeback] [data-mod-name=tool] .mostread li{height:auto;overflow:visible}[data-mod-name=welcomeback] [data-mod-name=tool] .mostread li .text{height:auto}}[data-mod-name=welcomeback] .greetings{display:inline-block;padding-right:calc(var(--gap)*2);font-size:2.2rem;line-height:2.8rem;font-weight:700;margin:0}[data-mod-name=welcomeback] .top__mailcom__logo{background-image:/*savepage-url=../../../module_assets/welcomeback/logo_mailcom_blue.svg*/url();background-repeat:no-repeat;height:3rem;cursor:pointer}[data-mod-name=welcomeback] .top__mailcom__blog__wrapper{padding-top:2.6rem;display:flex}[data-mod-name=welcomeback] .top__mailcom__blog__wrapper .greetings{line-height:4rem;padding-right:3rem}[data-mod-name=welcomeback] .top__mailcom__blog__wrapper .btn{margin:0;position:static;background-color:var(--button-wbs)}[data-mod-name=welcomeback] .top__mailcom__blog__wrapper .btn:hover{background-color:var(--button-hover-primary)}[data-mod-name=welcomeback] .hint{font-size:1.2rem;line-height:2.2rem;float:right;color:#333}[data-mod-name=welcomeback] .hint:hover{color:#3678ed}
