-name=footer] .nav{display:flex;margin-bottom:6rem;justify-content:center}}[data-mod-name=footer] .nav>li:before{font-family:Icons;content:"\e601";position:absolute;top:0;right:0;width:var(--mobile-footer-item-height);height:var(--mobile-footer-item-height);text-align:center;font-size:1.6rem;line-height:42px;pointer-events:none}[data-mod-name=footer] .nav>li.open:before{font-family:Icons;content:"\e602"}[data-mod-name=footer] .nav>li.open .subnav{display:block}@media (min-width:48em){[data-mod-name=footer] .nav>li{flex:0 1 22.5%;margin:0 2rem}[data-mod-name=footer] .nav>li:before{display:none}}@media (min-width:64em){[data-mod-name=footer] .nav>li{flex:0 1 20%}}@media (min-width:88.75em){[data-mod-name=footer] .nav>li{flex:0 1 17%}}@media (min-width:48em){[data-mod-name=footer] .links{text-align:center;font-size:0;line-height:0;margin-bottom:1rem}[data-mod-name=footer] .links>li{display:inline-block}[data-mod-name=footer] .links>li:last-of-type>a,[data-mod-name=footer] .links>li:last-of-type>span{border-right:0}[data-mod-name=footer] .links>li>a,[data-mod-name=footer] .links>li>span{border-bottom:0;border-right:1px solid #ccc;display:block;padding:0 .8rem;line-height:2.2rem}[data-mod-name=footer] .links>li>a.active,[data-mod-name=footer] .links>li>span.active{color:var(--brand-color)}}[data-mod-name=footer] .subnav{margin:0;padding:0;display:none}.no-js [data-mod-name=footer] .subnav{display:block}@media (min-width:48em){[data-mod-name=footer] .subnav{display:block}}[data-mod-name=footer] .subnav>li{list-style-type:none;padding-left:1rem;border-top:1px solid #ccc}@media (min-width:48em){[data-mod-name=footer] .subnav>li{padding:0;border:0}}[data-mod-name=footer] .subnav>li>a,[data-mod-name=footer] .subnav>li>span{font-size:1.4rem;line-height:4.2rem;color:var(--portal-cadet);text-decoration:none;display:block;padding:0 0 0 1rem}[data-mod-name=footer] .subnav>li>a.active,[data-mod-name=footer] .subnav>li>span.active{color:var(--brand-color)}@media (min-width:48em){[data-mod-name=footer] .subnav>li>a,[data-mod-name=footer] .subnav>li>span{font-size:1.2rem;line-height:2.8rem;padding:0}}@media (min-width:64em){[data-mod-name=footer] .subnav>li>a:hover{color:var(--brand-color)}}[data-mod-name=footer] .copyright{padding:1rem 0}[data-mod-name=footer] .copyright p{text-align:center;margin:1rem 0;font-size:1rem;line-height:1.4rem;color:var(--portal-cadet)}[data-mod-name=footer] .copyright p .logo-1and1{--logo-size:5rem;position:relative;width:var(--logo-size);height:var(--logo-size);display:inline-block;background:#fff /*savepage-url=../../../module_assets/footer/logo_1and1.svg*/ url() no-repeat 0 0;background-size:var(--logo-size) var(--logo-size);text-indent:-999999px}[data-mod-name=footer] .copyright p:last-of-type{padding-top:2rem}[data-mod-name=footer] .social{display:flex;justify-content:center;padding:2rem 0;border-bottom:1px solid #ccc}@media (min-width:48em){[data-mod-name=footer] .social{border-bottom:0;padding:0 0 6rem}}[data-mod-name=footer] .social a{margin:0 1rem}@media (min-width:48em){[data-mod-name=footer] .social a{margin:0 1.5rem}}[data-mod-name=footer] .social a svg{width:4rem;height:4rem;fill:var(--portal-cadet)}[data-mod-name=footer] .social a.fb:hover svg{fill:#2e5d9c}[data-mod-name=footer] .social a.tw{border-radius:100%;border:3px solid var(--portal-cadet)}[data-mod-name=footer] .social a.tw:hover{border-color:#000}[data-mod-name=footer] .social a.tw:hover svg{fill:#000}[data-mod-name=footer] .social a.tw svg{transform:scale(.55);fill:var(--portal-cadet);width:auto;height:auto}[data-mod-name=footer] .social a.linkedin:hover svg{fill:#2867b2}[data-mod-name=footer] .social a.instagram:hover svg{fill:#e1306c}
